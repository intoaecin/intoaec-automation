# Browser mode for local Cucumber + Playwright runs.
# Headed mode opens a visible browser. Set HEADLESS=true or HEADED=false for headless runs.
HEADLESS=true
HEADED=true

# Headed runs pause after each step for observability. Set to 0 to run headed without delay.
STEP_DELAY_MS=2000

# Failure screenshots are off by default. Set to true when debugging failures.
SCREENSHOTS_ENABLED=false
